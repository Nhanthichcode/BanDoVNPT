<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %> - Hệ thống giám sát mạng lưới VNPT
    </title>
    <link rel="icon" type="image/png" href="/images/Mini%20logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
        }

        .bg-vnpt {
            background-color: #0072BC !important;
        }

        .table-hover tbody tr:hover {
            background-color: #f1f8ff;
            transition: 0.2s;
        }
    </style>
</head>

<body>
    <%- include('partials/banner') %>
        <%- include('partials/navbar') %>

            <div id="main-content" class="container-fluid px-4 flex-grow-1 mt-4 mb-5">

                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                    <div>
                        <h3 class="text-danger fw-bold mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Báo cáo sự
                            cố và Thu hồi</h3>
                        <p class="text-muted mb-0 mt-1">Quản lý các điểm kết nối đang gặp sự cố hoặc cần thu hồi thiết
                            bị</p>

                        <button class="btn btn-danger fw-bold shadow-sm mt-3" data-bs-toggle="modal"
                            data-bs-target="#modalBaoCaoMoi">
                            <i class="bi bi-megaphone-fill"></i> Báo cáo sự cố từ hiện trường
                        </button>
                    </div>
                    <div class="d-flex gap-3">
                        <div
                            class="bg-white px-4 py-2 rounded shadow-sm border border-danger border-opacity-25 text-center">
                            <div class="small text-muted fw-bold">Cần sửa chữa</div>
                            <div class="fs-4 text-danger fw-bolder">
                                <%= soLuongDo %>
                            </div>
                        </div>
                        <div
                            class="bg-white px-4 py-2 rounded shadow-sm border border-secondary border-opacity-25 text-center">
                            <div class="small text-muted fw-bold">Cần thu hồi</div>
                            <div class="fs-4 text-secondary fw-bolder">
                                <%= soLuongXam %>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 text-center">
                                <thead class="bg-light text-secondary">
                                    <tr>
                                        <th class="py-3 text-start ps-4">Khách hàng/Liên hệ</th>
                                        <th class="py-3 text-start">Địa chỉ/Tủ cáp</th>
                                        <th class="py-3">Trạng thái</th>
                                        <th class="py-3">Ghi chú (Lý do)</th>
                                        <th class="py-3">Cập nhật cuối</th>
                                        <th class="py-3">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (danhSachSuCo.length> 0) { %>
                                        <% danhSachSuCo.forEach(function(diem) { %>
                                            <tr>
                                                <td class="text-start ps-4">
                                                    <div class="fw-bold text-dark fs-6">
                                                        <%= diem.ten_khach_hang %>
                                                    </div>
                                                    <div class="small text-muted"><i class="bi bi-tag-fill"></i>
                                                        <%= diem.loai_khach_hang %>
                                                    </div>
                                                </td>

                                                <td class="text-start">
                                                    <div class="small text-dark fw-bold"><i
                                                            class="bi bi-geo-alt-fill text-danger"></i>
                                                        <%= diem.dia_chi %>
                                                    </div>
                                                    <div class="small text-muted"><i
                                                            class="bi bi-hdd-rack-fill text-primary"></i>
                                                        <%= diem.splitter_id ? diem.splitter_id.ten_splitter
                                                            : 'Chưa gán tủ' %>
                                                    </div>
                                                </td>

                                                <td>
                                                    <% if (diem.trang_thai_ket_noi.mau_sac==='Đỏ' ) { %>
                                                        <span class="badge bg-danger px-3 py-2 rounded-pill"><i
                                                                class="bi bi-x-circle-fill"></i> Sự cố mạng</span>
                                                        <% } else { %>
                                                            <span class="badge bg-secondary px-3 py-2 rounded-pill"><i
                                                                    class="bi bi-box-seam-fill"></i> Cần thu hồi</span>
                                                            <% } %>
                                                </td>

                                                <td>
                                                    <% if (diem.trang_thai_ket_noi.ly_do_su_co) { %>
                                                        <span class="text-danger small fw-bold">
                                                            <%= diem.trang_thai_ket_noi.ly_do_su_co %>
                                                        </span>
                                                        <% } else { %>
                                                            <span class="text-muted small fst-italic">Không có ghi
                                                                chú</span>
                                                            <% } %>
                                                </td>

                                                <td>
                                                    <div class="small text-muted">
                                                        <%= new
                                                            Date(diem.trang_thai_ket_noi.lan_kiem_tra_cuoi).toLocaleString('vi-VN')
                                                            %>
                                                    </div>
                                                </td>

                                                <td>
                                                    <% if (diem.trang_thai_ket_noi.mau_sac==='Đỏ' ) { %>

                                                        <% if (mapDangXuLy && mapDangXuLy[diem._id.toString()]) { %>
                                                            <button
                                                                class="btn btn-sm btn-warning text-dark fw-bold shadow-sm rounded-pill px-3"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#modalCapNhatTienDo"
                                                                onclick="chuanBiCapNhat('<%= mapDangXuLy[diem._id.toString()] %>', '<%= diem._id %>', '<%= diem.ten_khach_hang %>')">
                                                                <i class="bi bi-tools"></i> Cập nhật tiến độ
                                                            </button>
                                                            <% } else { %>
                                                                <button
                                                                    class="btn btn-sm btn-outline-danger fw-bold shadow-sm rounded-pill px-3"
                                                                    data-bs-toggle="modal"
                                                                    data-bs-target="#modalLapBaoCao"
                                                                    onclick="chuanBiLapBaoCao('<%= diem._id %>', '<%= diem.ten_khach_hang %>')">
                                                                    <i class="bi bi-file-earmark-medical"></i> Lập báo
                                                                    cáo
                                                                </button>
                                                                <% } %>

                                                                    <% } else { %>
                                                                        <button
                                                                            class="btn btn-sm btn-outline-success fw-bold shadow-sm rounded-pill px-3 me-1 mb-1"
                                                                            title="Gia hạn hợp đồng"
                                                                            data-bs-toggle="modal"
                                                                            data-bs-target="#modalGiaHan"
                                                                            onclick="chuanBiGiaHan('<%= diem._id %>', '<%= diem.ten_khach_hang %>', '<%= diem.thong_tin_hop_dong.ngay_het_han ? new Date(diem.thong_tin_hop_dong.ngay_het_han).toLocaleDateString(`vi-VN`) : `Chưa xác định` %>')">
                                                                            <i class="bi bi-calendar-plus"></i> Gia hạn
                                                                        </button>
                                                                        <button
                                                                            class="btn btn-sm btn-outline-secondary fw-bold shadow-sm rounded-pill px-3 mb-1"
                                                                            title="Thu hồi thiết bị & Hủy đường truyền"
                                                                            data-bs-toggle="modal"
                                                                            data-bs-target="#modalThuHoi"
                                                                            onclick="chuanBiThuHoi('<%= diem._id %>', '<%= diem.ten_khach_hang %>')">
                                                                            <i class="bi bi-trash"></i> Thu hồi
                                                                        </button>
                                                                        <% } %>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="6" class="text-center py-5 text-muted">
                                                            <i
                                                                class="bi bi-check-circle-fill text-success fs-1 d-block mb-2"></i>
                                                            Hiện tại không có sự cố nào trên mạng lưới.
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal fade" id="modalLapBaoCao" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content rounded-4 border-0 shadow-lg">
                        <form action="/baocao/lap-bao-cao" method="POST">
                            <div class="modal-header bg-danger text-white py-3">
                                <h5 class="modal-title fw-bold"><i class="bi bi-file-earmark-medical"></i> Lập báo cáo
                                    sự cố</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                    aria-label="Đóng"></button>
                            </div>
                            <div class="modal-body p-4">
                                <div class="alert alert-danger border-0 shadow-sm">
                                    Khách hàng: <strong id="ten_khach_hang_bc"></strong>
                                </div>

                                <input type="hidden" id="diem_ket_noi_id" name="diem_ket_noi_id">

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Phân loại sự cố <span
                                            class="text-danger">*</span></label>
                                    <select class="form-select border-danger shadow-sm" name="loai_su_co" required>
                                        <option value="" disabled selected>-- Chọn loại sự cố --</option>
                                        <option value="Lỗi cấu hình (PPPoE)">Lỗi cấu hình mạng (PPPoE)</option>
                                        <option value="Đứt cáp quang">Đứt cáp quang ngoài tuyến</option>
                                        <option value="Mất điện trạm/tủ">Mất điện khu vực/tủ cáp</option>
                                        <option value="Hỏng thiết bị (ONT/Router)">Hỏng thiết bị (ONT/Router)</option>
                                        <option value="Suy hao tín hiệu cao">Suy hao tín hiệu cáp quang</option>
                                        <option value="Trộm/mất dây cáp">Trộm cắp / Mất dây cáp</option>
                                        <option value="Chưa rõ nguyên nhân">Khác / Chưa rõ nguyên nhân</option>
                                    </select>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label fw-bold">Mô tả ban đầu/Ghi chú</label>
                                    <textarea class="form-control shadow-sm" name="mo_ta_ban_dau" rows="3"
                                        placeholder="Ghi chú chi tiết tình trạng để kỹ thuật viên nắm bắt..."></textarea>
                                </div>
                            </div>
                            <div class="modal-footer bg-light mt-2">
                                <button type="button" class="btn btn-outline-secondary fw-bold rounded-pill px-4"
                                    data-bs-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-danger fw-bold rounded-pill px-4 shadow-sm">
                                    <i class="bi bi-send-fill"></i> Gửi báo cáo
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>




            <div class="modal fade" id="modalGiaHan" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content rounded-4 border-0 shadow-lg">
                        <form action="/baocao/gia-han" method="POST">
                            <div class="modal-header bg-success text-white py-3">
                                <h5 class="modal-title fw-bold"><i class="bi bi-calendar-plus"></i> Gia hạn gói cước
                                </h5>
                                <button type="button" class="btn-close btn-close-white"
                                    data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body p-4">
                                <div class="alert alert-success border-0 shadow-sm">
                                    Gia hạn cho KH: <strong id="ten_khach_hang_gh"></strong>
                                </div>
                                <input type="hidden" id="diem_id_giahan" name="diem_ket_noi_id">

                                <p class="small text-muted mb-3">Ngày hết hạn cũ: <strong id="ngay_het_han_cu"
                                        class="text-danger"></strong></p>

                                <div class="mb-2">
                                    <label class="form-label fw-bold text-success">Số tháng gia hạn <span
                                            class="text-success">*</span></label>
                                    <select class="form-select border-success shadow-sm fw-bold" name="so_thang_gia_han"
                                        required>
                                        <option value="6">6 tháng</option>
                                        <option value="12" selected>12 tháng</option>
                                        <option value="1">1 tháng</option>
                                    </select>
                                </div>
                            </div>
                            <div class="modal-footer bg-light mt-2">
                                <button type="button" class="btn btn-outline-secondary fw-bold rounded-pill px-4"
                                    data-bs-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-success fw-bold rounded-pill px-4 shadow-sm">
                                    <i class="bi bi-check-circle-fill"></i> Xác nhận gia hạn
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="modalThuHoi" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content rounded-4 border-0 shadow-lg">
                        <form action="/baocao/thu-hoi" method="POST">
                            <div class="modal-header bg-secondary text-white py-3">
                                <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Xác nhận
                                    thu hồi</h5>
                                <button type="button" class="btn-close btn-close-white"
                                    data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body p-4">
                                <div class="alert alert-warning border-0 shadow-sm">
                                    Bạn sắp thu hồi thiết bị và hủy đường truyền của khách hàng: <strong
                                        id="ten_khach_hang_th" class="text-danger"></strong>
                                </div>
                                <input type="hidden" id="diem_id_thuhoi" name="diem_ket_noi_id">
                                <p class="text-muted small mb-0">Hành động này sẽ <b>XÓA VĨNH VIỄN</b> điểm kết nối này
                                    khỏi bản đồ giám sát. Không thể hoàn tác!</p>
                            </div>
                            <div class="modal-footer bg-light mt-2">
                                <button type="button" class="btn btn-outline-secondary fw-bold rounded-pill px-4"
                                    data-bs-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-danger fw-bold rounded-pill px-4 shadow-sm">
                                    <i class="bi bi-trash-fill"></i> Xác nhận hủy và thu hồi
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>


            <div class="modal fade" id="modalCapNhatTienDo" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content rounded-4 border-0 shadow-lg">
                        <form action="/baocao/cap-nhat" method="POST">
                            <div class="modal-header bg-warning py-3">
                                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-tools"></i> Cập nhật tiến độ
                                    sửa chữa</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"
                                    aria-label="Đóng"></button>
                            </div>
                            <div class="modal-body p-4">
                                <div class="alert alert-warning border-0 shadow-sm text-dark">
                                    Khách hàng: <strong id="ten_khach_hang_cn"></strong>
                                </div>

                                <input type="hidden" id="bao_cao_id_cn" name="bao_cao_id">
                                <input type="hidden" id="diem_ket_noi_id_cn" name="diem_ket_noi_id">

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Chi tiết công việc đã thực hiện <span
                                            class="text-danger">*</span></label>
                                    <textarea class="form-control shadow-sm border-warning" name="noi_dung_cap_nhat"
                                        rows="3" placeholder="VD: Đã xuống hiện trường hàn nối lại cáp quang bị đứt..."
                                        required></textarea>
                                </div>

                                <div class="mb-2">
                                    <label class="form-label fw-bold">Trạng thái hiện tại <span
                                            class="text-danger">*</span></label>
                                    <select class="form-select border-warning shadow-sm fw-bold text-dark"
                                        name="trang_thai_moi" required>
                                        <option value="1">Đang xử lý </option>
                                        <option value="2">Đã khắc phục xong</option>
                                    </select>
                                </div>
                            </div>
                            <div class="modal-footer bg-light mt-2">
                                <button type="button" class="btn btn-outline-secondary fw-bold rounded-pill px-4"
                                    data-bs-dismiss="modal">Hủy</button>
                                <button type="submit"
                                    class="btn btn-warning text-dark fw-bold rounded-pill px-4 shadow-sm">
                                    <i class="bi bi-send-fill"></i> Lưu nhật ký
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <div class="modal fade" id="modalBaoCaoMoi" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content rounded-4 border-0 shadow-lg">
                        <form action="/baocao/lap-bao-cao" method="POST">
                            <div class="modal-header bg-danger text-white py-3">
                                <h5 class="modal-title fw-bold"><i class="bi bi-megaphone-fill"></i> BÁO CÁO SỰ CỐ MỚI
                                </h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                    aria-label="Đóng"></button>
                            </div>
                            <div class="modal-body p-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Chọn điểm kết nối gặp sự cố <span
                                            class="text-danger">*</span></label>
                                    <select class="form-select border-danger" name="diem_ket_noi_id"
                                        id="chon_diem_su_co" onchange="hienThiThongTinDiem()" required>
                                        <option value="" disabled selected>-- Tìm và chọn khách hàng / Điểm kết nối --
                                        </option>
                                        <% if (typeof danhSachBinhThuong !=='undefined' ) { %>
                                            <% danhSachBinhThuong.forEach(function(diem) { %>
                                                <option value="<%= diem._id %>" data-diachi="<%= diem.dia_chi %>"
                                                    data-loai="<%= diem.loai_khach_hang %>">
                                                    <%= diem.ten_khach_hang %> (<%= diem.dia_chi %>)
                                                </option>
                                                <% }); %>
                                                    <% } %>
                                    </select>
                                </div>

                                <div class="bg-light p-3 rounded mb-3 border" id="panel_thong_tin_diem"
                                    style="display: none;">
                                    <h6 class="fw-bold text-primary border-bottom pb-2">Thông tin điểm kết nối</h6>
                                    <div class="row">
                                        <div class="col-md-4"><span class="text-muted small">Loại hình:</span> <strong
                                                id="hien_thi_loai_kh" class="text-dark"></strong></div>
                                        <div class="col-md-8"><span class="text-muted small">Địa chỉ:</span> <strong
                                                id="hien_thi_dia_chi" class="text-dark"></strong></div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Sự cố báo cáo là gì? <span
                                            class="text-danger">*</span></label>
                                    <select class="form-select border-danger shadow-sm" name="loai_su_co" required>
                                        <option value="" disabled selected>-- Chọn loại sự cố --</option>
                                        <option value="Lỗi cấu hình (PPPoE)">Lỗi cấu hình mạng (PPPoE)</option>
                                        <option value="Đứt cáp quang">Đứt cáp quang ngoài tuyến</option>
                                        <option value="Mất điện trạm/tủ">Mất điện khu vực/tủ cáp</option>
                                        <option value="Hỏng thiết bị (ONT/Router)">Hỏng thiết bị (ONT/Router)</option>
                                        <option value="Suy hao tín hiệu cao">Suy hao tín hiệu cáp quang</option>
                                        <option value="Trộm/mất dây cáp">Trộm cắp / Mất dây cáp</option>
                                        <option value="Chưa rõ nguyên nhân">Khác / Chưa rõ nguyên nhân</option>
                                    </select>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label fw-bold">Ghi chú sự cố</label>
                                    <textarea class="form-control shadow-sm" name="mo_ta_ban_dau" rows="3"
                                        placeholder="Nhập thêm chi tiết tình trạng để kỹ thuật viên dễ dàng xử lý..."></textarea>
                                </div>
                            </div>
                            <div class="modal-footer bg-light mt-2">
                                <button type="button" class="btn btn-outline-secondary fw-bold rounded-pill px-4"
                                    data-bs-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-danger fw-bold rounded-pill px-4 shadow-sm">
                                    <i class="bi bi-send-fill"></i> Báo cáo
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>


            <%- include('partials/footer') %>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

                <script>
                    //Hàm chuẩn bị cho Modal Lập báo cáo
                    function chuanBiLapBaoCao(id, tenKhachHang) {
                        document.getElementById('diem_ket_noi_id').value = id;
                        document.getElementById('ten_khach_hang_bc').innerText = tenKhachHang;
                    }

                    //Hàm chuẩn bị cho Modal Cập nhật tiến độ
                    function chuanBiCapNhat(baoCaoId, diemId, tenKhachHang) {
                        document.getElementById('bao_cao_id_cn').value = baoCaoId;
                        document.getElementById('diem_ket_noi_id_cn').value = diemId;
                        document.getElementById('ten_khach_hang_cn').innerText = tenKhachHang;
                    }

                    //Hàm chuẩn bị cho Modal Gia hạn hợp đồng
                    function chuanBiGiaHan(id, ten, hanCu) {
                        document.getElementById('diem_id_giahan').value = id;
                        document.getElementById('ten_khach_hang_gh').innerText = ten;
                        document.getElementById('ngay_het_han_cu').innerText = hanCu;
                    }

                    //Hàm chuẩn bị cho Modal Thu hồi thiết bị
                    function chuanBiThuHoi(id, ten) {
                        document.getElementById('diem_id_thuhoi').value = id;
                        document.getElementById('ten_khach_hang_th').innerText = ten;
                    }

                    //Hàm hiển thị thông tin điểm khi chọn trong Modal Báo cáo mới
                    function hienThiThongTinDiem() {
                        const select = document.getElementById('chon_diem_su_co');
                        const option = select.options[select.selectedIndex];

                        if (option.value !== "") {
                            document.getElementById('panel_thong_tin_diem').style.display = 'block';
                            document.getElementById('hien_thi_loai_kh').innerText = option.getAttribute('data-loai');
                            document.getElementById('hien_thi_dia_chi').innerText = option.getAttribute('data-diachi');
                        } else {
                            document.getElementById('panel_thong_tin_diem').style.display = 'none';
                        }
                    }
                </script>
</body>

</html>