<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'Trang chủ' %> - Hệ thống giám sát VNPT</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="icon" type="image/png" href="/images/Mini%20logo.png">

    <style>
        /* 1. Bố cục trang tổng thể */
        body { background-color: #f8f9fa; display: flex; flex-direction: column; min-height: 100vh; margin: 0; }
        .bg-vnpt { background-color: #0072BC !important; }
        
        /* 2. Thống kê Card */
        .stat-card { border: none; border-radius: 10px; box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075); transition: transform 0.2s;}
        .stat-card:hover { transform: translateY(-3px); }
        .icon-box { width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 24px; }
        
        /* 3. Hiệu ứng chớp nháy (ĐÃ SỬA LỖI BỎ SCALE ĐỂ KHÔNG BỊ LƠ LỬNG) */
        @keyframes pulse-danger {
            0% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.8); }
            70% { box-shadow: 0 0 0 15px rgba(220, 53, 69, 0); }
            100% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); }
        }
        .marker-danger-icon {
            background-color: #dc3545; color: white; border-radius: 50%; border: 2px solid white;
            display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 14px;
            animation: pulse-danger 1.5s infinite;
        }

        /* 4. Dropdown Menu & Bản đồ */
        .dropdown-menu-list { max-height: 300px; overflow-y: auto; width: 320px; }
        .dropdown-menu-list::-webkit-scrollbar { width: 6px; }
        .dropdown-menu-list::-webkit-scrollbar-thumb { background-color: #ccc; border-radius: 10px; }
        .leaflet-container { z-index: 1 !important; }

        /* 5. Container giới hạn chiều cao bảng */
        .table-container-scroll {
            max-height: 65vh; /* Dùng vh thay vì dvh để tương thích nhiều trình duyệt hơn */
            overflow-y: auto;
            border: 1px solid #dee2e6; 
            position: relative;
        }
        .table-container-scroll thead th {
            position: sticky;
            top: 0;
            background-color: #f8f9fa; 
            z-index: 2;
            border-bottom: 2px solid #dee2e6;
        }

        /* 6. Sidebar và Footer */
        .sidebar {
            position: sticky;
            top: 0;              
            overflow-y: auto;
            z-index: 1000;
        }
        .footer-thin {
            padding: 0.5rem 0; 
            font-size: 0.75rem; 
            border-top: 1px solid rgba(255,255,255,0.1);
        }
    </style>

    <%- typeof stylesheet !== 'undefined' ? stylesheet : '' %>
</head>
<body>
    <%- include('../partials/banner.ejs') %>
    <%- include('../partials/navbar.ejs') %>

    <div class="container-fluid flex-grow-1">
        <div class="row h-100">
            <%- include('../partials/sidebar.ejs') %>

            <%- body %>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
       // 1. Khởi tạo: Ưu tiên lấy giá trị đã lưu trong localStorage, nếu không có thì mặc định là 1.0
    let currentScale = parseFloat(localStorage.getItem('interfaceScale')) || 1.0;

    // Hàm áp dụng tỷ lệ scale lên giao diện
    function applyScale() {
    const mainContent = document.querySelector('main');
    if (!mainContent) return;

    mainContent.style.zoom = currentScale;
    
    const scaleDisplay = document.getElementById('scale-level');
    if (scaleDisplay) {
        scaleDisplay.innerText = Math.round(currentScale * 100) + '%';
    }

    // Quan trọng: Ép bản đồ vẽ lại để không bị lỗi vị trí
    if (window.appMap) {
        setTimeout(() => {
            window.appMap.invalidateSize();
        }, 300); // Đợi hiệu ứng zoom hoàn tất
    }
}

    // Hàm điều khiển thu phóng
    function scaleContent(action) {
        if (action === 'in' && currentScale < 1.5) {
            currentScale += 0.1;
        } else if (action === 'out' && currentScale > 0.5) {
            currentScale -= 0.1;
        } else if (action === 'reset') {
            currentScale = 0.8;
        }

        currentScale = Math.round(currentScale * 10) / 10;

        // LƯU TRỮ: Ghi nhớ giá trị này vào trình duyệt
        localStorage.setItem('interfaceScale', currentScale);

        applyScale();
    }

    // 2. TỰ ĐỘNG CHẠY: Khi trang vừa load xong, áp dụng ngay mức zoom cũ
    document.addEventListener('DOMContentLoaded', function() {
        applyScale();
    });
</script>
    <%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>