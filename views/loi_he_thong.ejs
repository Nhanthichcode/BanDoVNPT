<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> - Hệ thống giám sát VNPT</title>
    <link rel="icon" type="image/png" href="/images/Mini%20logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f8f9fa; display: flex; flex-direction: column; min-height: 100vh; margin: 0; }
        .bg-vnpt { background-color: #0072BC !important; }
    </style>
</head>
<body>
    <%- include('partials/banner') %>
    <%- include('partials/navbar') %>

    <div id="main-content" class="container flex-grow-1 d-flex justify-content-center align-items-center mt-4 mb-5">
        <div class="text-center p-5 bg-white shadow border-0 rounded-4" style="max-width: 600px; border-top: 6px solid #dc3545 !important;">
            
            <i class="bi bi-database-fill-x text-danger mb-3" style="font-size: 5rem;"></i>
            
            <h2 class="fw-bold text-dark mt-2">Lỗi Kết Nối Máy Chủ</h2>
            
            <p class="text-muted fs-5 mt-3 mb-4 px-3">
                <%= typeof errorMsg !== 'undefined' ? errorMsg : 'Hệ thống đang gặp sự cố khi kết nối đến Cơ sở dữ liệu. Vui lòng thử lại sau ít phút.' %>
            </p>
            
            <a href="/" class="btn bg-vnpt text-white fw-bold px-4 py-2 rounded-pill shadow-sm">
                <i class="bi bi-house-door"></i> Trở về trang chủ
            </a>
            <button onclick="window.location.reload();" class="btn btn-outline-secondary fw-bold px-4 py-2 rounded-pill shadow-sm ms-2">
                <i class="bi bi-arrow-clockwise"></i> Thử lại
            </button>
        </div>
    </div>

    <%- include('partials/footer') %>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>