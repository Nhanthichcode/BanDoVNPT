<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cập nhật mật khẩu - Hệ thống giám sát VNPT</title>
    <link rel="icon" type="image/png" href="/images/Mini%20logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
        }

        .bg-vnpt {
            background-color: #0072BC !important;
        }
    </style>
</head>

<body>
    <%- include('partials/banner') %>
        <%- include('partials/navbar') %>

            <div id="main-content" class="container flex-grow-1 mt-5 mb-5" style="max-width: 700px;">
                <div class="card border-0 shadow rounded-4 overflow-hidden">
                    <div class="card-header bg-warning text-dark py-3">
                        <h4 class="mb-0 fw-bold"><i class="bi bi-key-fill"></i> CẬP NHẬT MẬT KHẨU</h4>
                    </div>

                    <div class="card-body p-5">
                        <% if (typeof error !=='undefined' && error) { %>
                            <div class="alert alert-danger fw-bold shadow-sm"><i
                                    class="bi bi-exclamation-triangle-fill"></i>
                                <%= error %>
                            </div>
                            <% } %>

                                <% if (step===1) { %>
                                    <form action="/taikhoan/matkhau_doi_xacthuc" method="POST">
                                        <div class="alert alert-secondary border-0 mb-4">
                                            Vui lòng xác minh danh tính trước khi thực hiện thay đổi mật khẩu.
                                        </div>
                                        <div class="row g-4">
                                            <div class="col-12">
                                                <label class="form-label fw-bold">Tên đăng nhập</label>
                                                <input type="text" class="form-control bg-light text-muted"
                                                    name="ten_dang_nhap" value="<%= user.ten_dang_nhap %>" readonly>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label fw-bold">Mật khẩu hiện tại</label>
                                                <input type="password" class="form-control" name="mat_khau_cu" required>
                                            </div>
                                        </div>
                                        <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                                            <a href="/taikhoan/capnhat"
                                                class="btn btn-outline-secondary me-2 fw-bold px-4 rounded-pill">Hủy</a>
                                            <button type="submit"
                                                class="btn btn-warning fw-bold px-4 rounded-pill shadow-sm">Xác nhận
                                                danh tính</button>
                                        </div>
                                    </form>

                                    <% } else if (step===2) { %>
                                        <form action="/taikhoan/matkhau_doi_xuly" method="POST">
                                            <div class="row g-4">
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold text-muted">Tên đăng nhập</label>
                                                    <input type="text" class="form-control bg-light text-muted"
                                                        value="<%= tenDangNhapXacThuc %>" readonly>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold text-muted">Mật khẩu hiện
                                                        tại</label>
                                                    <input type="password" class="form-control bg-light text-muted"
                                                        value="********" readonly>
                                                </div>

                                                <div class="col-12">
                                                    <hr class="text-muted opacity-25 my-1">
                                                </div>

                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold text-success">Mật khẩu mới</label>
                                                    <input type="password" class="form-control border-success"
                                                        name="mat_khau_moi" required autofocus>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold text-success">Nhập lại mật khẩu
                                                        mới</label>
                                                    <input type="password" class="form-control border-success"
                                                        name="nhap_lai_mat_khau_moi" required>
                                                </div>
                                            </div>

                                            <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                                                <button type="submit"
                                                    class="btn btn-success fw-bold px-4 rounded-pill shadow-sm me-2">
                                                    <i class="bi bi-floppy"></i> Lưu thay đổi
                                                </button>
                                                <a href="/taikhoan/capnhat"
                                                    class="btn btn-outline-secondary fw-bold px-4 rounded-pill">Hủy</a>
                                            </div>
                                        </form>
                                        <% } %>
                    </div>
                </div>
            </div>

            <%- include('partials/footer') %>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>