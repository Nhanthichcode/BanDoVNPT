   
    <style>
        body {
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
        }

        .bg-vnpt {
            background-color: #0072BC !important;
        }

        .table-hover tbody tr:hover {
            background-color: #f1f8ff;
            transition: 0.2s;
        }
    </style>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 mb-5">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                    <div>
                        <h3 class="text-primary fw-bold mb-0"><i class="bi bi-journal-text text-warning"></i>LỊCH SỬ BÁO
                            CÁO</h3>
                        <p class="text-muted mb-0 mt-1">Tra cứu các sự cố đã ghi nhận trên hệ thống</p>
                    </div>
                    <div>
                        <button onclick="xuatFileExcel()" class="btn btn-success fw-bold shadow-sm">
                            <i class="bi bi-file-earmark-excel"></i> Xuất file Excel
                        </button>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table id="bangLichSu" class="table table-hover align-middle mb-0 text-center">
                                <thead class="bg-light text-secondary">
                                    <tr>
                                        <th class="py-3">Trường hợp</th>
                                        <th class="py-3 text-start">Loại sự cố</th>
                                        <th class="py-3 text-start">Địa chỉ</th>
                                        <th class="py-3">Người báo cáo</th>
                                        <th class="py-3">Ngày báo cáo</th>
                                        <th class="py-3">Tình trạng xử lý</th>
                                        <th class="py-3">Ngày khắc phục</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (danhSachBaoCao.length> 0) { %>
                                        <% danhSachBaoCao.forEach(function(bc) { %>
                                            <tr>
                                                <td class="fw-bold text-primary">
                                                    <%= bc.ma_truong_hop %>
                                                </td>

                                                <td class="text-start fw-bold text-danger">
                                                    <%= bc.loai_su_co %>
                                                </td>

                                                <td class="text-start small text-dark"><i class="bi bi-geo-alt"></i>
                                                    <%= bc.dia_chi %>
                                                </td>

                                                <td><span class="badge bg-light text-dark border"><i
                                                            class="bi bi-person"></i>
                                                        <%= bc.nguoi_bao_cao %>
                                                    </span></td>

                                                <td class="small text-muted">
                                                    <%= new Date(bc.ngay_bao_cao).toLocaleString('vi-VN') %>
                                                </td>

                                                <td>
                                                    <% if (bc.trang_thai_xu_ly===2) { %>
                                                        <span class="badge bg-success px-3 py-2 rounded-pill">Đã khắc
                                                            phục</span>
                                                        <% } else { %>
                                                            <span
                                                                class="badge bg-warning text-dark px-3 py-2 rounded-pill">Đang
                                                                xử lý</span>
                                                            <% } %>
                                                </td>

                                                <td>
                                                    <% if (bc.trang_thai_xu_ly===2 && bc.ngay_khac_phuc) { %>
                                                        <span class="small text-success fw-bold">
                                                            <%= new Date(bc.ngay_khac_phuc).toLocaleString('vi-VN') %>
                                                        </span>
                                                        <% } else { %>
                                                            <span class="text-muted">-</span>
                                                            <% } %>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="7" class="text-center py-5 text-muted">Chưa có lịch
                                                            sử báo cáo nào.</td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div> 
</div>
                        
<script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
                <script>
                    function xuatFileExcel() {
                        //Lấy bảng bằng ID
                        var table = document.getElementById("bangLichSu");

                        //Chuyển HTML Table thành định dạng của SheetJS
                        var workbook = XLSX.utils.table_to_book(table, { sheet: "LichSuBaoCao" });

                        //Tải file xuống máy
                        XLSX.writeFile(workbook, 'LichSu_BaoCao_VNPT.xlsx');
                    }
                </script>
