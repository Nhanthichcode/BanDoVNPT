<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - Hệ thống giám sát mạng lưới VNPT</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { 
            background: linear-gradient(135deg, #e9f0f5 0%, #d4e0e8 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }
        .login-card { 
            width: 100%;
            max-width: 480px;
            border: none;
            border-radius: 24px;
            background: white;
            padding: 2rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            transition: transform 0.2s;
        }
        .login-card:hover {
            transform: translateY(-5px);
        }
        .bg-vnpt { background-color: #0072BC !important; }
        .btn-vnpt {
            background-color: #0072BC;
            color: white;
            transition: all 0.2s;
        }
        .btn-vnpt:hover {
            background-color: #005a91;
            transform: scale(1.02);
        }
        .form-control:focus {
            border-color: #0072BC;
            box-shadow: 0 0 0 0.2rem rgba(0,114,188,0.25);
        }
        .brand-icon {
            font-size: 3rem;
            color: #0072BC;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <i class="bi bi-hdd-stack-fill brand-icon"></i>
            <h5 class="text-secondary fw-bold mt-3 mb-1">HỆ THỐNG GIÁM SÁT MẠNG LƯỚI</h5>
            <h1 class="fw-bolder" style="color: #004a8f; font-size: 2.2rem;">ĐĂNG NHẬP</h1>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger py-3 text-center fw-bold"><%= error %></div>
        <% } %>

        <form action="/dangnhap" method="POST">
            <div class="mb-3">
                <label class="form-label fw-bold text-muted">Tên đăng nhập</label>
                <input type="text" name="username" class="form-control form-control-lg bg-light" 
                       placeholder="Nhập tên đăng nhập" autofocus 
                       value="<%= typeof oldUsername !== 'undefined' ? oldUsername : '' %>">
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold text-muted">Mật khẩu</label>
                <input type="password" name="password" class="form-control form-control-lg bg-light" placeholder="Nhập mật khẩu">
            </div>
            <button type="submit" class="btn btn-vnpt w-100 fw-bold py-3 fs-5 rounded-3 shadow-sm">ĐĂNG NHẬP</button>
        </form>

        <div class="text-center mt-4 small text-muted">
            © 2025 VNPT - Giám sát hạ tầng
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>