
    <style>
        body { background-color: #f8f9fa; display: flex; flex-direction: column; min-height: 100vh; margin: 0; }
        .bg-vnpt { background-color: #0072BC !important; }
        
        .stat-card { border: none; border-radius: 10px; box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075); transition: transform 0.2s;}
        .stat-card:hover { transform: translateY(-3px); }
        .icon-box { width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 24px; }
        

        /* Định dạng dropdown list mượt mà */
        /* Tìm và thay thế đoạn này trong thẻ <style> */
.dropdown-menu-list { 
    max-height: 320px; 
    overflow-y: auto; 
    min-width: 260px; /* Thu gọn kích thước tối thiểu */
    width: max-content; /* Tự động co giãn ôm vừa nội dung */
    max-width: 350px; /* Khống chế không cho quá to */
}
.dropdown-menu-list::-webkit-scrollbar { width: 6px; }
.dropdown-menu-list::-webkit-scrollbar-thumb { background-color: #adb5bd; border-radius: 10px; }
        .leaflet-container {z-index: 1 !important;}
  
  /* Tạo hiệu ứng phát sáng cho đường trục (Trunk line) */
.trunk-line-glow {
    filter: drop-shadow(0 0 3px rgba(0,0,0,0.5));
}

/* Hiệu ứng đường nhánh trông mềm mại hơn */
.dist-line-style {
    stroke-linecap: round;
}

/* Bảng chú thích (Legend) nằm trên bản đồ */
.map-legend {
    background: white;
    padding: 10px;
    border-radius: 8px;
    box-shadow: 0 0 15px rgba(0,0,0,0.2);
    line-height: 1.5;
    font-size: 12px;
}
.legend-item { display: flex; align-items: center; margin-bottom: 5px; }
.legend-color { width: 20px; height: 10px; margin-right: 8px; border-radius: 2px; }

.topo-node {
            background-color: #212529; /* Nền đen xám đậm */
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 8px rgba(0,0,0,0.4);
        }
        
        /* Viền đứt khúc và kích thước theo cấp độ */
        .node-tucap1 { border: 3px dashed #fd7e14; width: 44px !important; height: 44px !important; }
        .node-tucap2 { border: 3px dashed #0d6efd; width: 34px !important; height: 34px !important; }
        
        /* Trạng thái khách hàng */
        .node-kh-xanh { border: 3px dashed #198754; width: 28px !important; height: 28px !important; }
        .node-kh-do { border: 3px dashed #dc3545; width: 28px !important; height: 28px !important; animation: pulse-danger 1.5s infinite; }
        .node-kh-xam { border: 3px dashed #6c757d; width: 28px !important; height: 28px !important; }
</style>


 
<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-3">
   <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-3 mb-4" style="position: relative; z-index: 10;">    
        <% if (user.vai_tro_id === 1 || user.vai_tro_id === 2) { %>
            <div class="col">
                <div class="card stat-card h-100 p-3">
                    <div class="d-flex align-items-center">
                        <div class="icon-box bg-primary bg-opacity-10 text-primary me-3"><i class="bi bi-people-fill"></i></div>
                        <div>
                            <h6 class="text-muted mb-1">Tổng người dùng</h6>
                            <h3 class="fw-bold mb-0 text-dark"><%= stats.users %></h3>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <div class="col">
            <div class="card stat-card h-100 p-3 dropdown" style="cursor: pointer;">
                <div data-bs-toggle="dropdown" title="Click để xem danh sách">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <div class="icon-box bg-info bg-opacity-10 text-info me-3"><i class="bi bi-hdd-network-fill"></i></div>
                            <div>
                                <h6 class="text-muted mb-1">Tủ cáp<i class="bi bi-caret-down-fill small"></i></h6>
                                <h3 class="fw-bold mb-0 text-dark" id="splitter-count">0</h3>
                            </div>
                        </div>
                    </div>
                </div>
                <ul class="dropdown-menu dropdown-menu-list shadow border-0 mt-2 p-2" id="splitter-dropdown-list">
                    <li><span class="dropdown-item text-muted small text-center">Đang tải dữ liệu...</span></li>
                </ul>
            </div>
        </div>

        <div class="col">
            <div class="card stat-card h-100 p-3 dropdown" style="cursor: pointer;">
                <div data-bs-toggle="dropdown" title="Click để xem danh sách">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <div class="icon-box bg-danger bg-opacity-10 text-danger me-3"><i class="bi bi-tools"></i></div>
                            <div>
                                <h6 class="text-muted mb-1">Sự cố chờ xử lý <i class="bi bi-caret-down-fill small"></i></h6>
                                <h3 class="fw-bold mb-0 text-dark"><%= stats.issues || stats.myPendingIssues || 0 %></h3>
                            </div>
                        </div>
                    </div>
                </div>
                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-list shadow border-0 mt-2 p-2">
                    <li><h6 class="dropdown-header text-danger fw-bold px-2 border-bottom pb-2 mb-2"><i class="bi bi-fire"></i> Đang chờ xử lý</h6></li>
                    <% if (pendingList && pendingList.length > 0) { %>
                        <% pendingList.forEach(item => { %>
                            <li>
                                <a class="dropdown-item py-2 px-3 rounded text-wrap" href="javascript:void(0)" onclick="zoomToMap('<%= item.diem_ket_noi_id %>')">
                                    <div class="fw-bold text-dark"><%= item.ten_khach_hang %></div>
                                    <div class="small text-danger"><i class="bi bi-exclamation-circle"></i> <%= item.loai_su_co %></div>
                                    <div class="small text-muted" style="font-size: 0.7rem;"><%= new Date(item.thoi_gian_tao).toLocaleString('vi-VN') %></div>
                                </a>
                            </li>
                        <% }) %>
                    <% } else { %>
                        <li><span class="dropdown-item text-muted small text-center">Không có sự cố nào!</span></li>
                    <% } %>
                </ul>
            </div>
        </div>

        <div class="col">
            <div class="card stat-card h-100 p-3 dropdown" style="cursor: pointer;">
                <div data-bs-toggle="dropdown" title="Click để xem danh sách">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <div class="icon-box bg-success bg-opacity-10 text-success me-3"><i class="bi bi-check-circle-fill"></i></div>
                            <div>
                                <h6 class="text-muted mb-1">Đã khắc phục <i class="bi bi-caret-down-fill small"></i></h6>
                                <h3 class="fw-bold mb-0 text-dark"><%= stats.myResolvedIssues !== undefined ? stats.myResolvedIssues : resolvedList.length %></h3>
                            </div>
                        </div>
                    </div>
                </div>
                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-list shadow border-0 mt-2 p-2">
                    <li><h6 class="dropdown-header text-success fw-bold px-2 border-bottom pb-2 mb-2"><i class="bi bi-check2-all"></i> Vừa khắc phục xong</h6></li>
                    <% if (resolvedList && resolvedList.length > 0) { %>
                        <% resolvedList.forEach(item => { %>
                            <li>
                                <a class="dropdown-item py-2 px-3 rounded text-wrap" href="/baocao/lich-su">
                                    <div class="fw-bold text-dark"><%= item.ten_khach_hang %></div>
                                    <div class="small text-success"><i class="bi bi-wrench"></i> <%= item.loai_su_co %></div>
                                    <div class="small text-muted" style="font-size: 0.7rem;"><%= new Date(item.thoi_gian_tao).toLocaleString('vi-VN') %></div>
                                </a>
                            </li>
                        <% }) %>
                    <% } else { %>
                        <li><span class="dropdown-item text-muted small text-center">Chưa có dữ liệu!</span></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </div>

    <div class="card stat-card p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-map-fill me-2 text-primary"></i>Giám sát bản đồ trực tuyến</h5>
                    <div id="map-dashboard" style="height: 480px; border-radius: 10px; z-index: 1;" class="border shadow-sm">
                        <div class="h-100 d-flex align-items-center justify-content-center bg-light">
                            <div class="spinner-border text-primary me-2" role="status"></div>
                            <span>Đang tải dữ liệu mạng lưới...</span>
                        </div>
                    </div>
                </div>
            </main>

<script>
    // 1. Khai báo biến toàn cục
    window.appMap = null;
    window.appMarkers = {};
    window.appSplitterMarkers = {};

    document.addEventListener('DOMContentLoaded', function() {
        const mapContainer = document.getElementById('map-dashboard');

        if (window.appMap !== null) {
            window.appMap.remove();
            window.appMap = null;
        }
        if (mapContainer && mapContainer._leaflet_id) {
            mapContainer._leaflet_id = null;
        }

        try {
            window.appMap = L.map('map-dashboard').setView([10.37, 105.43], 14);

            L.tileLayer('http://{s}.google.com/vt/lyrs=y&x={x}&y={y}&z={z}', {
                maxZoom: 20,
                minZoom: 6,
                noWrap: true,
                bounds: [[8.0, 102.0], [24.0, 110.0]],
                subdomains: ['mt0', 'mt1', 'mt2', 'mt3'],
                attribution: '© Google Maps'
            }).addTo(window.appMap);

            window.appMap.setMaxBounds([[5.0, 95.0], [25.0, 115.0]]);
        } catch (e) {
            console.error("Lỗi khi tạo bản đồ:", e);
        }

        // 2. TẢI DỮ LIỆU ĐỒNG THỜI
        Promise.all([
            fetch('/api/diem-ket-noi').then(res => res.json()),
            fetch('/api/splitters').then(res => res.json())
        ])
        .then(([khachHangData, splitterData]) => {
            const uniqueSplitters = {}; 
            const uniqueSplittersCap1 = {}; 

            // --- BƯỚC A: VẼ HẠ TẦNG TỦ CÁP ---
            if (splitterData && splitterData.length > 0) {
                splitterData.forEach(sp => {
                    if (sp.vi_tri && sp.vi_tri.coordinates) {
                        const [spLng, spLat] = sp.vi_tri.coordinates;
                        const spId = String(sp._id).toLowerCase().trim();

                        if (sp.loai_splitter === '1:4') {
                            uniqueSplittersCap1[spId] = sp;
                            const iconTu1 = L.divIcon({
                                className: 'topo-node node-tucap1',
                                html: '<i class="bi bi-hdd-rack-fill fs-5" style="color: #fd7e14"></i>',
                                iconSize: [44, 44], iconAnchor: [22, 22]
                            });
                            const sp1Marker = L.marker([spLat, spLng], { icon: iconTu1 }).addTo(window.appMap);

                            sp1Marker.bindPopup(`
                                <div style="min-width: 170px; text-align: center;">
                                    <h6 class="text-warning fw-bold mb-2 border-bottom pb-2"><i class="bi bi-hdd-rack-fill"></i> ${sp.ten_splitter}</h6>
                                    <span class="badge bg-dark text-white mb-3 px-3 py-2 rounded-pill shadow-sm">TỦ CẤP 1 | ${sp.sys_id || 'N/A'}</span>
                                    <a href="/splitter" class="btn btn-sm btn-outline-warning text-dark w-100 fw-bold shadow-sm rounded-pill">
                                        <i class="bi bi-pencil-square"></i> Quản lý / Sửa
                                    </a>
                                </div>
                            `);
                            window.appSplitterMarkers[spId] = sp1Marker;
                        } else {
                            uniqueSplitters[spId] = sp;
                            const iconTu2 = L.divIcon({
                                className: 'topo-node node-tucap2',
                                html: '<i class="bi bi-router-fill" style="color: #0d6efd"></i>',
                                iconSize: [34, 34], iconAnchor: [17, 17]
                            });
                            const sp2Marker = L.marker([spLat, spLng], { icon: iconTu2 }).addTo(window.appMap);
                            
                            sp2Marker.bindPopup(`
                                <div style="min-width: 170px; text-align: center;">
                                    <h6 class="text-info fw-bold mb-2 border-bottom pb-2"><i class="bi bi-router-fill"></i> ${sp.ten_splitter}</h6>
                                    <span class="badge bg-light text-dark border mb-3 px-3 py-2 rounded-pill shadow-sm">TỦ CẤP 2 | ${sp.sys_id || 'N/A'}</span>
                                    <a href="/splitter" class="btn btn-sm btn-outline-info text-dark w-100 fw-bold shadow-sm rounded-pill">
                                        <i class="bi bi-pencil-square"></i> Quản lý / Sửa
                                    </a>
                                </div>
                            `);
                            window.appSplitterMarkers[spId] = sp2Marker;

                            if (sp.splitter_cha_id) {
                                const spCha = splitterData.find(s => String(s._id) === String(sp.splitter_cha_id));
                                if (spCha && spCha.vi_tri && spCha.vi_tri.coordinates) {
                                    L.polyline([ [spCha.vi_tri.coordinates[1], spCha.vi_tri.coordinates[0]], [spLat, spLng] ], {
                                        color: '#fd7e14', weight: 4, dashArray: '16, 25', opacity: 0.9, className: 'trunk-line-glow'
                                    }).addTo(window.appMap);
                                }
                            }
                        }
                    }
                });
            }

            // ==========================================
            // BƯỚC B: VẼ KHÁCH HÀNG & ĐƯỜNG DÂY SỰ CỐ
            // ==========================================
            if (khachHangData && khachHangData.length > 0) {
                khachHangData.forEach(diem => {
                    if (diem.vi_tri && diem.vi_tri.coordinates) {
                        const [lng, lat] = diem.vi_tri.coordinates;
                        const isError = diem.trang_thai_ket_noi.mau_sac === 'Đỏ';
                        
                        let iconClass = isError ? 'node-kh-do' : (diem.trang_thai_ket_noi.mau_sac === 'Xám' ? 'node-kh-xam' : 'node-kh-xanh');
                        let iconColor = isError ? '#dc3545' : (diem.trang_thai_ket_noi.mau_sac === 'Xanh' ? '#198754' : '#6c757d');

                        const iconKH = L.divIcon({
                            className: `topo-node ${iconClass}`,
                            html: `<i class="bi bi-house-door-fill" style="color: ${iconColor}"></i>`,
                            iconSize: [28, 28], iconAnchor: [14, 14]
                        });

                        let marker = L.marker([lat, lng], { icon: iconKH }).addTo(window.appMap);
                        window.appMarkers[String(diem._id).toLowerCase().trim()] = marker;

                        // --- POPUP THÔNG TIN ---
                        let popupContent = `
                            <div style="min-width: 220px;">
                                <div class="d-flex align-items-center mb-2 border-bottom pb-2">
                                    <div class="bg-${isError ? 'danger' : 'success'} text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 36px; height: 36px; font-size: 16px;">
                                        <i class="bi bi-house-door-fill"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold text-dark mb-0 text-wrap">${diem.ten_khach_hang}</h6>
                                        <small class="text-${isError ? 'danger fw-bold' : 'success'}">${isError ? `Đang gặp sự cố` : 'Đang hoạt động'}</small>
                                    </div>
                                </div>
                                <p class="text-muted small mb-3"><i class="bi bi-geo-alt-fill text-secondary"></i> ${diem.dia_chi}</p>
                                <div class="d-flex gap-2">
                                    <a href="/diemketnoi/sua/${diem._id}" class="btn btn-sm btn-outline-secondary w-100 fw-bold rounded-pill">Sửa KH</a>
                                    ${isError ? `<a href="/baocao/su-co" class="btn btn-sm btn-danger w-100 fw-bold rounded-pill">Xử lý</a>` : ''}
                                </div>
                            </div>`;
                        marker.bindPopup(popupContent);

                        // --- LOGIC ĐỔI MÀU ĐƯỜNG DẪN KHI CÓ SỰ CỐ ---
                        if (diem.splitter_id && diem.splitter_id.vi_tri) {
                            const [sp2Lng, sp2Lat] = diem.splitter_id.vi_tri.coordinates;
                            
                            L.polyline([ [lat, lng], [sp2Lat, sp2Lng] ], {
                                color: isError ? '#dc3545' : '#aea', // ĐỎ khi lỗi, XÁM khi thường
                                weight: isError ? 5 : 3,               // Dày hơn khi lỗi
                                opacity: isError ? 8.0 : 0.7,
                                dashArray: isError ? '6, 15' : '6, 6', // Nét đứt thưa hơn khi lỗi
                                lineCap: 'round'
                            }).addTo(window.appMap);
                        }
                    }
                });
            }                        
            
            // ==========================================
            // BƯỚC C: ĐỔ DỮ LIỆU VÀO MENU DROPDOWN TỦ CÁP
            // ==========================================
            const splitterListEl = document.getElementById('splitter-dropdown-list');
            const splitterCountEl = document.getElementById('splitter-count');
            
            // Chuyển đối tượng thành mảng để xử lý
            const splArr1 = Object.values(uniqueSplittersCap1);
            const splArr2 = Object.values(uniqueSplitters);
            const allSplitters = [...splArr1, ...splArr2];

            // 1. Cập nhật số lượng tủ cáp lên nhãn hiển thị
            if (splitterCountEl) {
                splitterCountEl.innerText = allSplitters.length;
            }

            // 2. Đổ danh sách vào Dropdown
            if (splitterListEl) {
                splitterListEl.innerHTML = ''; // Xóa trắng nội dung cũ

                if (allSplitters.length === 0) {
                    splitterListEl.innerHTML = '<li><a class="dropdown-item disabled">Không có dữ liệu tủ</a></li>';
                } else {
                    // Thêm tiêu đề nhóm Tủ Cấp 1
                    if (splArr1.length > 0) {
                        splitterListEl.innerHTML += `<li><h6 class="dropdown-header text-warning"><i class="bi bi-hdd-rack-fill"></i> TỦ CẤP 1 (1:4)</h6></li>`;
                        splArr1.forEach(sp => {
                            splitterListEl.innerHTML += `
                                <li>
                                    <a class="dropdown-item d-flex justify-content-between align-items-center" href="javascript:void(0)" onclick="zoomToSplitter('${sp._id}')">
                                        <span>${sp.ten_splitter}</span>
                                        <small class="text-muted" style="font-size: 0.65rem;">${sp.sys_id || ''}</small>
                                    </a>
                                </li>`;
                        });
                    }

                    // Thêm gạch ngang phân cách
                    splitterListEl.innerHTML += `<li><hr class="dropdown-divider"></li>`;

                    // Thêm tiêu đề nhóm Tủ Cấp 2
                    if (splArr2.length > 0) {
                        splitterListEl.innerHTML += `<li><h6 class="dropdown-header text-primary"><i class="bi bi-router-fill"></i> TỦ CẤP 2 (1:16)</h6></li>`;
                        splArr2.forEach(sp => {
                            splitterListEl.innerHTML += `
                                <li>
                                    <a class="dropdown-item d-flex justify-content-between align-items-center" href="javascript:void(0)" onclick="zoomToSplitter('${sp._id}')">
                                        <span>${sp.ten_splitter}</span>
                                        <small class="text-muted" style="font-size: 0.65rem;">${sp.sys_id || ''}</small>
                                    </a>
                                </li>`;
                        });
                    }
                }
            }
        })
        .catch(err => console.error("Lỗi tải API Bản đồ:", err));
    });

    function zoomToMap(id) {
        const marker = window.appMarkers[String(id).toLowerCase().trim()];
        if (marker) performFlyTo(marker);
    }

    function zoomToSplitter(id) {
        const marker = window.appSplitterMarkers[String(id).toLowerCase().trim()];
        if (marker) performFlyTo(marker);
    }

    function performFlyTo(markerObj) {
        window.appMap.closePopup();
        document.getElementById('map-dashboard').scrollIntoView({ behavior: 'smooth', block: 'center' });
        setTimeout(() => {
            window.appMap.flyTo(markerObj.getLatLng(), 18, { animate: true, duration: 2.0 });
            window.appMap.once('moveend', () => markerObj.openPopup());
        }, 400);
    }    
</script>