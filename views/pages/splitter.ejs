  <title>
        <%= title %> - Hệ thống giám sát mạng lưới VNPT
    </title>
     
    <style>
        body {
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
        }

        .bg-vnpt {
            background-color: #0072BC !important;
        }

        .table-hover tbody tr:hover {
            background-color: #f1f8ff;
            transition: 0.2s;
        }
        /* Thêm vào bên trong thẻ <style> */
        #map-picker { 
            height: 500px; 
            width: 100%; 
            border-radius: 0 0 15px 15px;
        }
        .leaflet-container { z-index: 1 !important; }
    </style>
 
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-3">            

                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                    <div>
                        <h3 class="text-primary fw-bold mb-0"><i class="bi bi-hdd-rack text-danger"></i> QUẢN LÝ
                            SPLITTER/Tủ PON</h3>
                    </div>
                    <div>
                        <button class="btn bg-vnpt text-white fw-bold shadow-sm" data-bs-toggle="modal"
                            data-bs-target="#modalThemSplitter">
                            <i class="bi bi-plus-circle"></i> Thêm Splitter
                        </button>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-0">
                        <div class="table-container-scroll">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light text-secondary">
                                    <tr>
                                        <th class="text-center py-3">STT</th>
                                        <th class="py-3">Tên tủ</th>
                                        <th class="py-3 text-center">Loại</th>
                                        <th class="py-3">SysID</th>
                                        <th class="py-3">Nguồn cáp</th>
                                        <th class="py-3 text-center">Trạng thái</th>
                                        <th class="py-3 text-center">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (typeof danhSachSplitter !=='undefined' && danhSachSplitter.length> 0) { %>
                                        <% danhSachSplitter.forEach(function(sp, index) { %>
                                            <tr>
                                                <td class="text-center text-muted fw-bold">
                                                    <%= index + 1 %>
                                                </td>
                                                <td><span class="fw-bold text-dark"><i class="bi bi-hdd-network"></i>
                                                        <%= sp.ten_splitter %>
                                                    </span></td>
                                                <td class="text-center">
                                                    <% if(sp.loai_splitter==='1:4' ) { %>
                                                        <span class="badge bg-primary px-2 py-1">Cấp 1 (<%=
                                                                sp.loai_splitter %>)</span>
                                                        <% } else { %>
                                                            <span class="badge bg-info text-dark px-2 py-1">Cấp 2 (<%=
                                                                    sp.loai_splitter %>)</span>
                                                            <% } %>
                                                </td>
                                                <td class="text-danger fw-bold">
                                                    <%= sp.sys_id %>
                                                </td>
                                                <td>
                                                    <% if(sp.splitter_cha_id) { %>
                                                        <span class="text-primary fw-bold">
                                                            <%= sp.splitter_cha_id.ten_splitter %>
                                                        </span>
                                                        <% } else { %>
                                                            <span class="text-success fw-bold"><i
                                                                    class="bi bi-server"></i> Nối thẳng trạm OLT</span>
                                                            <% } %>
                                                </td>
                                                <td class="text-center">
                                                    <% if(sp.trang_thai === 'Hoạt động') { %>
                                                    <span class="badge bg-success rounded-pill">
                                                        Hoạt động
                                                    </span>
                                                    <% } else { %>
                                                        <span class="badge bg-warning rounded-pill text">
                                                            Ngưng hoạt động
                                                        </span>
                                                        <% } %>
                                                </td>
                                           <td class="text-center">
                                                <div class="d-flex justify-content-center gap-2">
                                                    <button class="btn btn-sm btn-warning fw-bold text-dark shadow-sm"
                                                        onclick="chuanBiSuaSplitter('<%= sp._id %>', '<%= sp.ten_splitter %>', '<%= sp.sys_id %>', '<%= sp.loai_splitter %>', '<%= sp.splitter_cha_id ? sp.splitter_cha_id._id : '' %>', '<%= sp.vi_tri.coordinates[1] %>', '<%= sp.vi_tri.coordinates[0] %>')"
                                                        data-bs-toggle="modal" data-bs-target="#modalSuaSplitter">
                                                        <i class="bi bi-pencil-square"></i> Sửa
                                                    </button>
                                                    
                                                    <form action="/splitter/xoa/<%= sp._id %>" method="POST" onsubmit="return confirm('Bạn chắc chắn muốn xóa tủ cáp này?')">
                                                        <button type="submit" class="btn btn-sm btn-danger fw-bold shadow-sm"><i class="bi bi-trash"></i> Xóa</button>
                                                    </form>
                                                </div>
                                            </td>
                                            </tr>
                                            <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="7" class="text-center py-5 text-muted">
                                                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                                            Chưa có tủ Splitter nào trong CSDL.
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
           

            <div class="modal fade" id="modalThemSplitter" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content border-0 shadow">
                        <div class="modal-header bg-vnpt text-white">
                            <h5 class="modal-title fw-bold"><i class="bi bi-node-plus"></i> THÊM TỦ PON</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <form action="/splitter/them" method="POST">
                            <div class="modal-body p-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Tên tủ</label>
                                    <input type="text" name="ten_splitter" class="form-control"
                                        placeholder="VD: Tủ cấp 1 - Nguyễn Thái Học..." required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">SysID</label> // Mã trạm OLT
                                    <input type="text" name="sys_id" class="form-control text-danger fw-bold"
                                        value="AGG-LX-01" required>
                                </div>
                               <div class="row g-3 mb-3">
                                    <div class="col-md-12">
                                        <label class="form-label fw-bold">Tọa độ vị trí</label>
                                        <div class="input-group">
                                            <input type="number" step="any" name="vi_do" id="input_vi_do" class="form-control"
                                                placeholder="Vĩ độ (VD: 10.37)" min="-90" max="90" required>
                                            <input type="number" step="any" name="kinh_do" id="input_kinh_do" class="form-control"
                                                placeholder="Kinh độ (VD: 105.43)" min="-180" max="180" required>
                                            <button type="button" class="btn btn-outline-primary fw-bold" data-bs-toggle="modal" data-bs-target="#modalPickLocation">
                                                <i class="bi bi-geo-alt-fill"></i> Chọn từ bản đồ
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <hr>

                                <div class="mb-3">
                                    <label class="form-label fw-bold text-primary">Loại tủ</label>
                                    <select name="loai_splitter" id="loai_splitter" class="form-select border-primary"
                                        required onchange="kiemTraLoaiSplitter()">
                                        <option value="1:4">Cấp 1 (Chia 1:4) - Nối thẳng OLT</option>
                                        <option value="1:16">Cấp 2 (Chia 1:16) - Nối từ tủ Cấp 1</option>
                                    </select>
                                </div>

                                <div class="mb-3 d-none bg-light p-3 border rounded" id="khung_splitter_cha">
                                    <label class="form-label fw-bold text-danger"><i class="bi bi-link-45deg"></i> Nối
                                        vào tủ Cấp 1 nào?</label>
                                    <select name="splitter_cha_id" class="form-select">
                                        <option value="">-- Chọn tủ nguồn --</option>
                                        <% if (typeof danhSachSplitterCap1 !=='undefined' ) { %>
                                            <% danhSachSplitterCap1.forEach(function(sp) { %>
                                                <option value="<%= sp._id %>">
                                                    <%= sp.ten_splitter %> (<%= sp.sys_id %>)
                                                </option>
                                                <% }); %>
                                                    <% } %>
                                    </select>
                                </div>

                            </div>
                            <div class="modal-footer bg-light">
                                <button type="button" class="btn btn-secondary fw-bold" data-bs-target="#modalThemSplitter" data-bs-toggle="modal">Hủy</button>
                                <button type="submit" class="btn bg-vnpt text-white fw-bold shadow-sm"><i
                                        class="bi bi-floppy"></i> Lưu Tủ</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>     

            <div class="modal fade" id="modalSuaSplitter" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content border-0 shadow">
                        <div class="modal-header bg-warning text-dark">
                            <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square"></i> SỬA THÔNG TIN TỦ PON</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <form id="formSuaSplitter" method="POST">
                            <div class="modal-body p-4">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Tên tủ</label>
                                    <input type="text" name="ten_splitter" id="sua_ten_splitter" class="form-control" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">SysID (Mã trạm OLT)</label>
                                    <input type="text" name="sys_id" id="sua_sys_id" class="form-control text-danger fw-bold" required>
                                </div>
                                <div class="row g-3 mb-3">
                                    <div class="col-md-12">
                                        <label class="form-label fw-bold">Tọa độ vị trí</label>
                                        <div class="input-group">
                                            <input type="number" step="any" name="vi_do" id="sua_vi_do" class="form-control" required>
                                            <input type="number" step="any" name="kinh_do" id="sua_kinh_do" class="form-control" required>
                                            <button type="button" class="btn btn-outline-warning fw-bold text-dark" onclick="isEditingMap = true" data-bs-toggle="modal" data-bs-target="#modalPickLocation">
                                                <i class="bi bi-geo-alt-fill"></i> Chọn lại trên bản đồ
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <hr>
                                <div class="mb-3">
                                    <label class="form-label fw-bold text-primary">Loại tủ</label>
                                    <select name="loai_splitter" id="sua_loai_splitter" class="form-select border-primary" required onchange="kiemTraLoaiSplitterSua()">
                                        <option value="1:4">Cấp 1 (Chia 1:4) - Nối thẳng OLT</option>
                                        <option value="1:16">Cấp 2 (Chia 1:16) - Nối từ tủ Cấp 1</option>
                                    </select>
                                </div>
                                <div class="mb-3 d-none bg-light p-3 border rounded" id="sua_khung_splitter_cha">
                                    <label class="form-label fw-bold text-danger"><i class="bi bi-link-45deg"></i> Nối vào tủ Cấp 1 nào?</label>
                                    <select name="splitter_cha_id" id="sua_splitter_cha_id" class="form-select">
                                        <option value="">-- Chọn tủ nguồn --</option>
                                        <% if (typeof danhSachSplitterCap1 !=='undefined' ) { %>
                                            <% danhSachSplitterCap1.forEach(function(sp) { %>
                                                <option value="<%= sp._id %>"><%= sp.ten_splitter %> (<%= sp.sys_id %>)</option>
                                            <% }); %>
                                        <% } %>
                                    </select>
                                </div>
                            </div>
                            <div class="modal-footer bg-light">
                                <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-warning text-dark fw-bold shadow-sm"><i class="bi bi-floppy"></i> Cập nhật Tủ</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            </main>

                <div class="modal fade" id="modalPickLocation" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg" style="border-radius: 15px;">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title fw-bold"><i class="bi bi-geo-alt"></i> CHỌN VỊ TRÍ KHÁCH HÀNG</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body p-0">
                            <div id="map-picker"></div>
                        </div>
                        <div class="modal-footer bg-light d-flex justify-content-between">
                            <div>
                                <span class="badge bg-dark">Vĩ độ: <span id="display-lat">0</span></span>
                                <span class="badge bg-dark">Kinh độ: <span id="display-lng">0</span></span>
                            </div>
                            <div>
                                <!-- <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Hủy</button> -->
                                <button type="button" class="btn btn-secondary fw-bold" data-bs-target="#modalThemSplitter" data-bs-toggle="modal">Hủy</button>
                                <button type="button" class="btn btn-primary fw-bold" onclick="xacNhanToaDo()">Xác nhận vị trí</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        
                <script>
                    function kiemTraLoaiSplitter() {
                        var loai = document.getElementById('loai_splitter').value;
                        var khungCha = document.getElementById('khung_splitter_cha');
                        if (loai === '1:16') {
                            khungCha.classList.remove('d-none');
                        } else {
                            khungCha.classList.add('d-none');
                        }
                    }

                        let pickerMap;
    let tempMarker;

    const modalEl = document.getElementById('modalPickLocation');

    // Lắng nghe sự kiện Modal MỞ LÊN
    modalEl.addEventListener('shown.bs.modal', function () {      
        
        if (!pickerMap) {      
            try {
                pickerMap = L.map('map-picker').setView([10.37, 105.43], 15);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(pickerMap);
              
                pickerMap.on('click', function(e) {
                  
                    updateMarker(e.latlng.lat, e.latlng.lng);
                });
            } catch (err) {
                console.error("❌ [LỖI]: Không thể khởi tạo bản đồ:", err);
            }
        } else {
       
        }
        
        console.log("🔥 [DEBUG]: Gọi hàm invalidateSize() để sửa lỗi khung xám...");
        setTimeout(() => {
            pickerMap.invalidateSize();
            console.log("🔥 [DEBUG]: Xong invalidateSize()!");
        }, 100);
    });

    function updateMarker(lat, lng) {
        if (tempMarker) pickerMap.removeLayer(tempMarker);
        tempMarker = L.marker([lat, lng], { draggable: true }).addTo(pickerMap);
        
        document.getElementById('display-lat').innerText = lat.toFixed(6);
        document.getElementById('display-lng').innerText = lng.toFixed(6);

        tempMarker.on('dragend', function(event) {
            const pos = event.target.getLatLng();
            console.log("🔥 [DEBUG]: Kéo thả Marker đến:", pos);
            updateMarker(pos.lat, pos.lng);
        });
    }

    let isEditingMap = false;

    // 1. Hàm nhận dữ liệu từ nút Sửa và đổ vào Form
    function chuanBiSuaSplitter(id, ten, sys, loai, chaId, lat, lng) {
        document.getElementById('formSuaSplitter').action = '/splitter/sua/' + id;
        document.getElementById('sua_ten_splitter').value = ten;
        document.getElementById('sua_sys_id').value = sys;
        document.getElementById('sua_loai_splitter').value = loai;
        document.getElementById('sua_vi_do').value = lat;
        document.getElementById('sua_kinh_do').value = lng;

        const khungCha = document.getElementById('sua_khung_splitter_cha');
        if (loai === '1:16') {
            khungCha.classList.remove('d-none');
            document.getElementById('sua_splitter_cha_id').value = chaId;
        } else {
            khungCha.classList.add('d-none');
            document.getElementById('sua_splitter_cha_id').value = '';
        }
    }

    // 2. Ẩn/Hiện ô chọn Tủ Cấp 1 trong Form Sửa
    function kiemTraLoaiSplitterSua() {
        var loai = document.getElementById('sua_loai_splitter').value;
        var khungCha = document.getElementById('sua_khung_splitter_cha');
        if (loai === '1:16') {
            khungCha.classList.remove('d-none');
        } else {
            khungCha.classList.add('d-none');
        }
    }

    // 3. Thay thế/Nâng cấp hàm Xác nhận tọa độ cũ của bạn
    function xacNhanToaDo() {
        const lat = document.getElementById('display-lat').innerText;
        const lng = document.getElementById('display-lng').innerText;
        if (lat === "0") return alert("Vui lòng click chọn một điểm trên bản đồ!");
        
        // Trả tọa độ về đúng Form (Sửa hoặc Thêm)
        if (isEditingMap) {
            document.getElementById('sua_vi_do').value = lat;
            document.getElementById('sua_kinh_do').value = lng;
        } else {
            document.getElementById('input_vi_do').value = lat;
            document.getElementById('input_kinh_do').value = lng;
        }
        
        // Đóng Modal Bản đồ
        const mapModalEl = document.getElementById('modalPickLocation');
        const mapModal = bootstrap.Modal.getInstance(mapModalEl);
        mapModal.hide();

        // Tự động mở lại đúng Form tương ứng
        setTimeout(() => {
            const targetModalId = isEditingMap ? 'modalSuaSplitter' : 'modalThemSplitter';
            const formModalEl = document.getElementById(targetModalId);
            let formModal = bootstrap.Modal.getInstance(formModalEl);
            if (!formModal) formModal = new bootstrap.Modal(formModalEl);
            formModal.show();
        }, 400);
    }

        // Chức năng tự động bóc tách tọa độ từ đường dẫn Google Maps
    const inputViDo = document.getElementById('input_vi_do');
    
    inputViDo.addEventListener('paste', function(e) {
        // Lấy nội dung người dùng vừa dán vào ô
        const pastedText = (e.clipboardData || window.clipboardData).getData('text');
        
        // Kiểm tra xem đây có phải là đường dẫn Google Maps hay không
        if (pastedText.includes('google.com/maps') || pastedText.includes('maps.app.goo.gl')) {
            // Ngăn không cho dán nguyên đường dẫn dài ngoằng vào ô số
            e.preventDefault();
            
            // Tìm kiếm chuỗi tọa độ (VD: @10.37,105.43)
            const regex = /@(-?\d+\.\d+),(-?\d+\.\d+)/;
            const match = pastedText.match(regex);
            
            if (match) {
                // Tự động phân bổ vào hai ô
                document.getElementById('input_vi_do').value = match[1];
                document.getElementById('input_kinh_do').value = match[2];
                alert("Đã trích xuất tọa độ thành công từ đường dẫn!");
            } else {
                alert("Đường dẫn này không chứa tọa độ hiển thị rõ ràng. Hãy thử di chuyển bản đồ một chút và copy lại.");
            }
        }
    });
    
</script>