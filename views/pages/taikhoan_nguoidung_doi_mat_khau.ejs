    <title>Cập nhật mật khẩu - Hệ thống giám sát VNPT</title>

    <style>
        body {
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
        }

        .bg-vnpt {
            background-color: #0072BC !important;
        }
    </style>

<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-3">
    <div class="container" style="max-width: 800px;">
        <div class="card border-0 shadow rounded-4 overflow-hidden">
            <div class="card-header bg-warning text-dark py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-key-fill"></i> CẬP NHẬT MẬT KHẨU</h4>
            </div>

            <div class="card-body p-5">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger fw-bold shadow-sm">
                        <i class="bi bi-exclamation-triangle-fill"></i> <%= error %>
                    </div>
                <% } %>

                <form action="/taikhoan/doi-mat-khau" method="POST">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-bold">Tên đăng nhập</label>
                            <input type="text" class="form-control bg-light text-muted"
                                   value="<%= user.ten_dang_nhap %>" readonly>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Mật khẩu hiện tại</label>
                            <input type="password" class="form-control" name="mat_khau_cu" required autofocus>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-success">Mật khẩu mới</label>
                            <input type="password" class="form-control border-success" name="mat_khau_moi" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-success">Nhập lại mật khẩu mới</label>
                            <input type="password" class="form-control border-success" name="nhap_lai_mat_khau_moi" required>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-success fw-bold px-4 rounded-pill shadow-sm me-2">
                            <i class="bi bi-floppy"></i> Lưu thay đổi
                        </button>
                        <a href="/taikhoan" class="btn btn-outline-secondary fw-bold px-4 rounded-pill">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>