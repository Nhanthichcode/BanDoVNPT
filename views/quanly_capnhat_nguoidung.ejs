<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cập nhật người dùng - Hệ thống giám sát VNPT</title>
    <link rel="icon" type="image/png" href="/images/Mini%20logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f8f9fa; display: flex; flex-direction: column; min-height: 100vh; margin: 0; }
        .bg-vnpt { background-color: #0072BC !important; }
    </style>
</head>
<body>
    <%- include('banner') %>
    <%- include('navbar') %>

    <div class="container flex-grow-1 mt-5 mb-5" style="max-width: 800px;">
        <div class="card border-0 shadow rounded-4 overflow-hidden">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> CẬP NHẬT THÔNG TIN NGƯỜI DÙNG</h4>
            </div>
            
            <div class="card-body p-5">
                <div class="alert alert-info border-0 shadow-sm mb-4">
                    <i class="bi bi-info-circle-fill"></i> Đang chỉnh sửa thông tin cho tài khoản: <strong><%= taiKhoanSua.ten_dang_nhap %></strong>
                </div>

                <form action="/quanly/taikhoan/sua_xuly" method="POST">
                    <input type="hidden" name="ten_dang_nhap" value="<%= taiKhoanSua.ten_dang_nhap %>">

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" class="form-control border-primary shadow-sm" name="ho_ten" value="<%= taiKhoanSua.ho_ten %>" required autofocus>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                            <input type="text" class="form-control shadow-sm" name="so_dien_thoai" value="<%= taiKhoanSua.so_dien_thoai %>" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Email/Liên hệ khác</label>
                            <input type="text" class="form-control shadow-sm" name="email_lien_he" value="<%= taiKhoanSua.email_lien_he %>" placeholder="Không bắt buộc">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Địa chỉ</label>
                            <input type="text" class="form-control shadow-sm" name="dia_chi" value="<%= taiKhoanSua.dia_chi %>" placeholder="Không bắt buộc">
                        </div>

                        <div class="col-12"><hr class="text-muted opacity-25 my-1"></div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold text-danger"><i class="bi bi-shield-lock-fill"></i> Vai trò hệ thống <span class="text-danger">*</span></label>
                            <select class="form-select border-danger shadow-sm fw-bold" name="vai_tro_id">
                                <option value="1" <%= taiKhoanSua.vai_tro_id === 1 ? 'selected' : '' %>>Quản trị viên</option>
                                <option value="2" <%= taiKhoanSua.vai_tro_id === 2 ? 'selected' : '' %>>Quản lý</option>
                                <option value="3" <%= taiKhoanSua.vai_tro_id === 3 ? 'selected' : '' %>>Nhân viên</option>
                            </select>
                            <small class="text-muted">Cẩn trọng khi thay đổi vai trò của người dùng.</small>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-5 pt-3 border-top">
                        <a href="/quanly/taikhoan" class="btn btn-outline-secondary me-2 fw-bold px-4 rounded-pill shadow-sm">
                            <i class="bi bi-x-circle"></i> Hủy
                        </a>
                        <button type="submit" class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm">
                            <i class="bi bi-floppy"></i> Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>