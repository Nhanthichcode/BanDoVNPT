<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Chi tiết tài khoản - Hệ thống giám sát VNPT</title>
    <link rel="icon" type="image/png" href="/images/Mini%20logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f8f9fa; display: flex; flex-direction: column; min-height: 100vh; margin: 0; }
        .bg-vnpt { background-color: #0072BC !important; }
    </style>
</head>
<body>
    <%- include('banner') %>
    <%- include('navbar') %>

    <div class="container flex-grow-1 mt-5 mb-5" style="max-width: 800px;">
        <div class="card border-0 shadow rounded-4 overflow-hidden">
            <div class="card-header bg-info text-dark py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-person-lines-fill"></i> HỒ SƠ CHI TIẾT</h4>
            </div>
            
            <div class="card-body p-5">
                <div class="alert alert-info border-0 shadow-sm mb-4">
                    Đang xem hồ sơ của tài khoản: <strong><%= taiKhoanChiTiet.ho_ten %></strong>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted">Họ và tên</label>
                        <input type="text" class="form-control bg-light" value="<%= taiKhoanChiTiet.ho_ten %>" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted">Số điện thoại</label>
                        <input type="text" class="form-control bg-light" value="<%= taiKhoanChiTiet.so_dien_thoai %>" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted">Email/Liên hệ khác</label>
                        <input type="text" class="form-control bg-light" value="<%= taiKhoanChiTiet.email_lien_he || 'Chưa cập nhật' %>" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted">Vai trò hệ thống</label>
                        <input type="text" class="form-control bg-light text-primary fw-bold" value="<%= taiKhoanChiTiet.ten_vai_tro %>" readonly>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold text-muted">Địa chỉ</label>
                        <input type="text" class="form-control bg-light" value="<%= taiKhoanChiTiet.dia_chi || 'Chưa cập nhật' %>" readonly>
                    </div>
                    
                    <% if (taiKhoanChiTiet.trang_thai === 0) { %>
                        <div class="col-12">
                            <label class="form-label fw-bold text-danger">Lý do khóa tài khoản</label>
                            <textarea class="form-control bg-light border-danger text-danger" rows="2" readonly><%= taiKhoanChiTiet.ly_do_khoa %></textarea>
                        </div>
                    <% } %>
                </div>

                <hr class="text-muted opacity-25 mb-4">

                <% if (!showSensitive) { %>
                    <div class="card border-warning shadow-sm">
                        <div class="card-header bg-warning text-dark fw-bold">
                            <i class="bi bi-shield-lock-fill"></i> XÁC THỰC BẢO MẬT ĐỂ XEM THÔNG TIN ĐĂNG NHẬP
                        </div>
                        <div class="card-body">
                            <form action="/quanly/taikhoan/chitiet_xuly" method="POST">
                                <input type="hidden" name="ten_dang_nhap_muc_tieu" value="<%= taiKhoanChiTiet.ten_dang_nhap %>">
                                <p class="small text-muted mb-2">Thông tin đăng nhập là dữ liệu nhạy cảm. Vui lòng nhập mật khẩu của bạn để xác nhận quyền truy cập.</p>
                                <div class="input-group">
                                    <input type="password" class="form-control border-warning" name="mat_khau_admin" placeholder="Mật khẩu của bạn" required autofocus>
                                    <button class="btn btn-warning fw-bold" type="submit"><i class="bi bi-eye-fill"></i> Xác thực</button>
                                </div>
                            </form>
                        </div>
                    </div>
                <% } else { %>
                    <div class="card border-success shadow-sm">
                        <div class="card-header bg-success text-white fw-bold">
                            <i class="bi bi-unlock-fill"></i> THÔNG TIN ĐĂNG NHẬP
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-danger">Tên đăng nhập</label>
                                    <input type="text" class="form-control border-success text-danger fw-bold" value="<%= taiKhoanChiTiet.ten_dang_nhap %>" readonly>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-danger">Mật khẩu hiện tại</label>
                                    <input type="text" class="form-control border-success text-danger fw-bold" value="<%= taiKhoanChiTiet.mat_khau %>" readonly>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>

                <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                    <a href="/quanly/taikhoan" class="btn btn-outline-secondary fw-bold px-4 rounded-pill shadow-sm">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </div>
        </div>
    </div>

    <%- include('footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>