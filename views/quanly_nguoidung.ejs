<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> - Hệ thống giám sát VNPT</title>
    <link rel="icon" type="image/png" href="/images/Mini%20logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f8f9fa; display: flex; flex-direction: column; min-height: 100vh; margin: 0; }
        .bg-vnpt { background-color: #0072BC !important; }
        .table-hover tbody tr:hover { background-color: #f1f8ff; transition: 0.2s; }

        /* Hiệu ứng nút Khóa tài khoản */
        .btn-trangthai-khoa { transition: all 0.3s ease; }
        .btn-trangthai-khoa:hover { background-color: #dc3545 !important; border-color: #dc3545 !important; color: white !important; }
        .btn-trangthai-khoa .icon-dong { display: none; }
        .btn-trangthai-khoa:hover .icon-mo { display: none; }
        .btn-trangthai-khoa:hover .icon-dong { display: inline-block; }

        /* Hiệu ứng hover cho nút Mở khóa tài khoản */
        .btn-trangthai-mokhoa { transition: all 0.3s ease; }
        .btn-trangthai-mokhoa:hover { background-color: #198754 !important; border-color: #198754 !important; color: white !important; }
        .btn-trangthai-mokhoa .icon-mo-hover { display: none; }
        .btn-trangthai-mokhoa:hover .icon-dong-mac-dinh { display: none; }
        .btn-trangthai-mokhoa:hover .icon-mo-hover { display: inline-block; }
    </style>
</head>

<body>
    <%- include('banner') %>
    <%- include('navbar') %>

    <div class="container-fluid px-4 flex-grow-1 mt-4 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
            <div>
                <h3 class="text-primary fw-bold mb-0"><i class="bi bi-people-fill text-danger"></i> QUẢN LÝ NGƯỜI DÙNG</h3>
                <p class="text-muted mb-0 mt-1">Quản trị danh sách tài khoản và phân quyền hệ thống</p>
            </div>
            <div>
                <a href="/quanly/taikhoan/them" class="btn bg-vnpt text-white fw-bold shadow-sm">
                    <i class="bi bi-person-plus-fill"></i> Thêm tài khoản
                </a>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-center">
                        <thead class="bg-light text-secondary">
                            <tr>
                                <th class="py-3 text-start ps-4">Tài khoản/Họ tên</th>
                                <th class="py-3">Thông tin liên hệ</th>
                                <th class="py-3">Vai trò</th>
                                <th class="py-3">Trạng thái</th>
                                <th class="py-3">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof danhSachTaiKhoan !== 'undefined' && danhSachTaiKhoan.length > 0) { %>
                                <% danhSachTaiKhoan.forEach(function(tk) { %>
                                    <tr>
                                        <td class="text-start ps-4">
                                            <div class="fw-bold text-dark fs-6"><%= tk.ho_ten %></div>
                                            <div class="small text-muted"><i class="bi bi-person-bounding-box"></i> <%= tk.ten_dang_nhap %></div>
                                        </td>
                                        <td>
                                            <div class="small text-dark"><i class="bi bi-telephone-fill text-success"></i> <%= tk.so_dien_thoai %></div>
                                            <div class="small text-muted"><i class="bi bi-envelope-fill text-warning"></i> <%= tk.email_lien_he || 'Chưa cập nhật' %></div>
                                        </td>
                                        <td>
                                            <% if (tk.vai_tro_id === 1) { %>
                                                <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="bi bi-shield-lock-fill"></i> Quản trị viên</span>
                                            <% } else if (tk.vai_tro_id === 2) { %>
                                                <span class="badge bg-primary px-3 py-2 rounded-pill"><i class="bi bi-briefcase-fill"></i> Quản lý</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary px-3 py-2 rounded-pill"><i class="bi bi-person-fill"></i> Nhân viên</span>
                                            <% } %>
                                        </td>
                                        
                                        <td>
                                            <% if (tk.ten_dang_nhap === user.ten_dang_nhap) { %>
                                                <button class="btn btn-sm btn-outline-secondary shadow-sm px-2 py-1" title="Bạn không thể tự khóa tài khoản của mình" disabled>
                                                    <i class="bi bi-unlock fs-6 text-muted"></i>
                                                </button>
                                            <% } else { %>
                                                <% if (tk.trang_thai === 1) { %>
                                                    <button class="btn btn-sm btn-outline-success shadow-sm px-2 py-1 btn-trangthai-khoa"
                                                        title="Đang hoạt động - Nhấn để Khóa" data-bs-toggle="modal" data-bs-target="#modalKhoaTaiKhoan"
                                                        onclick="chuanBiKhoa('<%= tk.ten_dang_nhap %>', '<%= tk.ho_ten %>')">
                                                        <i class="bi bi-unlock fs-6 icon-mo"></i>
                                                        <i class="bi bi-lock-fill fs-6 icon-dong"></i>
                                                    </button>
                                                <% } else { %>
                                                    <button class="btn btn-sm btn-outline-danger shadow-sm px-2 py-1 btn-trangthai-mokhoa"
                                                        title="Đã khóa - Nhấn để Mở khóa" data-bs-toggle="modal" data-bs-target="#modalMoKhoaTaiKhoan"
                                                        onclick="chuanBiMoKhoa('<%= tk.ten_dang_nhap %>', '<%= tk.ho_ten %>', '<%= tk.ly_do_khoa || ',' %>')">
                                                        <i class="bi bi-lock-fill fs-6 icon-dong-mac-dinh"></i>
                                                        <i class="bi bi-unlock fs-6 icon-mo-hover"></i>
                                                    </button>
                                                <% } %>
                                            <% } %>
                                        </td>

                                        <td>
                                            <% if (tk.ten_dang_nhap === user.ten_dang_nhap) { %>
                                                <button class="btn btn-sm btn-outline-secondary shadow-sm me-1" title="Vui lòng vào 'Hồ sơ cá nhân' để tự chỉnh sửa" disabled>
                                                    <i class="bi bi-pencil-square text-muted"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary shadow-sm me-1" title="Vui lòng vào 'Hồ sơ cá nhân' để đổi mật khẩu" disabled>
                                                    <i class="bi bi-key text-muted"></i>
                                                </button>
                                            <% } else { %>
                                               <a href="/quanly/taikhoan/sua/<%= tk.ten_dang_nhap %>" class="btn btn-sm btn-outline-primary shadow-sm me-1" title="Chỉnh sửa">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>
                                                
                                                <button class="btn btn-sm btn-outline-warning shadow-sm me-1" title="Đặt lại mật khẩu mặc định"
                                                    data-bs-toggle="modal" data-bs-target="#modalDatLaiMatKhau"
                                                    onclick="chuanBiDatLaiMatKhau('<%= tk.ten_dang_nhap %>', '<%= tk.ho_ten %>')">
                                                    <i class="bi bi-arrow-clockwise"></i>
                                                </button>

                                                <a href="/quanly/taikhoan/chitiet/<%= tk.ten_dang_nhap %>" class="btn btn-sm btn-outline-info shadow-sm" title="Xem thông tin chi tiết">
                                                    <i class="bi bi-info-circle-fill"></i>
                                                </a>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i> Chưa có dữ liệu tài khoản.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div> <div class="modal fade" id="modalKhoaTaiKhoan" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content rounded-4 border-0 shadow-lg">
                <form action="/quanly/taikhoan/khoa_xuly" method="POST">
                    <div class="modal-header bg-danger text-white py-3">
                        <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> XÁC NHẬN KHÓA TÀI KHOẢN</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="alert alert-warning border-0 shadow-sm">
                            Bạn đang thực hiện khóa tài khoản: <strong id="ten_hien_thi_khoa" class="text-danger"></strong>
                        </div>
                        <input type="hidden" id="input_ten_dang_nhap_bi_khoa" name="ten_dang_nhap_bi_khoa">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Lý do khóa tài khoản <span class="text-danger">*</span></label>
                            <textarea class="form-control border-danger" name="ly_do_khoa" rows="2" placeholder="Nhập lý do vi phạm..." required autofocus></textarea>
                        </div>
                        <hr class="text-muted opacity-25">
                        <div class="mb-2">
                            <label class="form-label fw-bold text-primary"><i class="bi bi-shield-lock-fill"></i> Xác thực bảo mật</label>
                            <p class="small text-muted mb-2">Vui lòng nhập mật khẩu của bạn để xác nhận hành động này.</p>
                            <input type="password" class="form-control border-primary" name="mat_khau_xac_nhan" placeholder="Mật khẩu của bạn" required>
                        </div>
                    </div>
                    <div class="modal-footer bg-light mt-2">
                        <button type="button" class="btn btn-outline-secondary fw-bold rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger fw-bold rounded-pill px-4 shadow-sm">
                            <i class="bi bi-lock-fill"></i> Khóa tài khoản
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalMoKhoaTaiKhoan" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content rounded-4 border-0 shadow-lg">
                <form action="/quanly/taikhoan/mokhoa_xuly" method="POST">
                    <div class="modal-header bg-success text-white py-3">
                        <h5 class="modal-title fw-bold"><i class="bi bi-unlock-fill"></i> XÁC NHẬN MỞ KHÓA</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="alert alert-success border-0 shadow-sm">
                            Bạn đang thực hiện <b>khôi phục</b> tài khoản: <strong id="ten_hien_thi_mokhoa" class="text-success"></strong>
                        </div>
                        <input type="hidden" id="input_ten_dang_nhap_duoc_mo" name="ten_dang_nhap_duoc_mo">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted">Lý do bị khóa trước đó:</label>
                            <textarea class="form-control bg-light text-muted border-0" id="hien_thi_ly_do_khoa_cu" rows="2" readonly></textarea>
                        </div>
                        <hr class="text-muted opacity-25">
                        <div class="mb-2">
                            <label class="form-label fw-bold text-primary"><i class="bi bi-shield-lock-fill"></i> Xác thực bảo mật</label>
                            <p class="small text-muted mb-2">Vui lòng nhập mật khẩu của bạn để xác nhận hành động này.</p>
                            <input type="password" class="form-control border-primary" name="mat_khau_xac_nhan" placeholder="Mật khẩu của bạn" required>
                        </div>
                    </div>
                    <div class="modal-footer bg-light mt-2">
                        <button type="button" class="btn btn-outline-secondary fw-bold rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success fw-bold rounded-pill px-4 shadow-sm">
                            <i class="bi bi-unlock-fill"></i> Thực hiện mở khóa
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
<div class="modal fade" id="modalDatLaiMatKhau" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content rounded-4 border-0 shadow-lg">
                <form action="/quanly/taikhoan/datlai_matkhau_xuly" method="POST">
                    
                    <div class="modal-header bg-warning text-dark py-3">
                        <h5 class="modal-title fw-bold"><i class="bi bi-arrow-clockwise"></i> ĐẶT LẠI MẬT KHẨU</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                    </div>
                    
                    <div class="modal-body p-4">
                        <div class="alert alert-warning border-0 shadow-sm">
                            Bạn đang yêu cầu đặt lại mật khẩu cho tài khoản: <strong id="ten_hien_thi_datlai" class="text-danger"></strong>
                        </div>
                        
                        <p class="text-muted small mb-3">
                            <i class="bi bi-info-circle-fill text-primary"></i> 
                            Hệ thống sẽ tự động đặt lại mật khẩu của tài khoản này trở về giá trị mặc định là: <strong class="text-danger fs-6 px-1">abc123</strong>
                        </p>
                        
                        <input type="hidden" id="input_ten_dang_nhap_datlai" name="ten_dang_nhap_datlai">

                        <hr class="text-muted opacity-25">

                        <div class="mb-2">
                            <label class="form-label fw-bold text-primary"><i class="bi bi-shield-lock-fill"></i> Xác thực bảo mật</label>
                            <p class="small text-muted mb-2">Vui lòng nhập mật khẩu của bạn để xác nhận thao tác này.</p>
                            <input type="password" class="form-control border-primary" name="mat_khau_xac_nhan" placeholder="Mật khẩu của bạn" required>
                        </div>
                    </div>
                    
                    <div class="modal-footer bg-light mt-2">
                        <button type="button" class="btn btn-outline-secondary fw-bold rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-warning text-dark fw-bold rounded-pill px-4 shadow-sm">
                            <i class="bi bi-check-circle-fill"></i> Xác nhận đặt lại
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
    <script>
        function chuanBiKhoa(tenDangNhap, hoTen) {
            document.getElementById('ten_hien_thi_khoa').innerText = hoTen + ' (' + tenDangNhap + ')';
            document.getElementById('input_ten_dang_nhap_bi_khoa').value = tenDangNhap;
        }

        function chuanBiMoKhoa(tenDangNhap, hoTen, lyDoKhoa) {
            document.getElementById('ten_hien_thi_mokhoa').innerText = hoTen + ' (' + tenDangNhap + ')';
            document.getElementById('input_ten_dang_nhap_duoc_mo').value = tenDangNhap;
            document.getElementById('hien_thi_ly_do_khoa_cu').value = lyDoKhoa || 'Không có ghi chú lý do.';
        }
        function chuanBiDatLaiMatKhau(tenDangNhap, hoTen) {
            document.getElementById('ten_hien_thi_datlai').innerText = hoTen + ' (' + tenDangNhap + ')';
            document.getElementById('input_ten_dang_nhap_datlai').value = tenDangNhap;
        }
    </script>

    <%- include('footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>